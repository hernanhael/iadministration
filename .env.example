# ============================================================================
# Variables de entorno — gastos-app
# Copiá este archivo a .env.local y completá los valores.
# .env.local NUNCA se commitea (está en .gitignore).
# ============================================================================

# --- Públicas (visibles en el navegador, seguras por diseño: RLS es la barrera) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Solo servidor (NUNCA exponer al cliente) ---
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# --- Cron: importación automática de facturas por Gmail (solo servidor) ---
# Obtenidos con: npx tsx scripts/gmail-auth.ts
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=            # informativo/logs, no lo usa la API
CRON_USER_ID=                # uuid del único usuario de la app (mismo valor que MIGRATION_USER_ID)
CRON_SECRET=                 # lo genera Vercel al crear el cron job; se valida como Bearer token
