# ============================================================================
# Variables de entorno — gastos-app
# Copiá este archivo a .env.local y completá los valores.
# .env.local NUNCA se commitea (está en .gitignore).
# ============================================================================

# --- Públicas (visibles en el navegador, seguras por diseño: RLS es la barrera) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Solo servidor (NUNCA exponer al cliente) ---
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# --- Cron de facturas por email (src/app/api/cron/facturas-gmail) ---
# GMAIL_CLIENT_ID / GMAIL_CLIENT_SECRET: credencial OAuth "Desktop app" de
# Google Cloud (Gmail API, scope gmail.readonly). GMAIL_REFRESH_TOKEN se
# obtiene una vez con `npx tsx scripts/obtener-refresh-token-gmail.ts`.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# CRON_SECRET: protege el endpoint del cron (header Authorization: Bearer).
# Generar con, por ejemplo, `openssl rand -base64 32`.
CRON_SECRET=
